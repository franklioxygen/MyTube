PORT={backend_port}
SECURITY_MODEL=strict
HOOK_EXECUTION_MODE=inline
SECURITY_AUDIT_RETENTION_DAYS=90
SECURITY_ALERT_WINDOW_RETENTION_DAYS=7
# Platform-managed mount directory allowlist (JSON array)
# Example:
# PLATFORM_MOUNT_DIRECTORIES=[{"id":"library","label":"Main Library","path":"/mnt/library"},{"id":"archive","path":"/srv/archive"}]
PLATFORM_MOUNT_DIRECTORIES=[]
