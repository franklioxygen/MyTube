PORT={backend_port}
# Optional: point Puppeteer to a system Chrome/Chromium binary.
# Example macOS:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Optional: show a visible Chrome window for sites that block headless automation.
# PUPPETEER_HEADLESS=false
# Deployment security model for admin capabilities: application | container | host
# Default: container
# MYTUBE_ADMIN_TRUST_LEVEL=container
# Optional: yt-dlp JS runtime for YouTube challenge solving.
# Default: deno
# Use node on Alpine Linux (musl) if deno is unstable.
# YT_DLP_JS_RUNTIME=node
